# API server
PORT=3000

# Required. API key clients must send in the `x-api-key` header.
# The server rejects all /api requests when this is unset (fails closed).
API_KEY=

# Comma-separated list of allowed browser origins for CORS.
# Requests from disallowed origins are rejected. Leave empty to allow
# only same-origin / non-browser (no Origin header) clients.
CORS_ALLOWED_ORIGINS=

# Max JSON request body size (default 1mb).
JSON_BODY_LIMIT=1mb

# Google Generative AI (Gemini) API key used by @ai-sdk/google.
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional Gemini model overrides.
GEMINI_CHAT_MODEL=gemini-flash-latest
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# PostgreSQL connection string for candidate storage.
DATABASE_URL=
# Optional table name (default: candidates).
POSTGRES_TABLE=candidates

# Qdrant vector database connection.
QDRANT_URL=
QDRANT_API_KEY=
# Optional collection name (default: candidates).
QDRANT_COLLECTION=candidates
